# .env.example
# Copy this file to .env and modify it to override the llm_config.yaml settings

# Think Model Overrides
LLM_THINK_ENDPOINT=http://external-api:8080/v1
LLM_THINK_MODEL=external-think-model
LLM_THINK_API_KEY=your_external_api_key
# LLM_THINK_TEMPERATURE=0.7
# LLM_THINK_MAX_TOKENS=4096

# Instruct Model Overrides
LLM_INSTRUCT_ENDPOINT=http://external-api:8080/v1
LLM_INSTRUCT_MODEL=external-instruct-model
LLM_INSTRUCT_API_KEY=your_external_api_key
# LLM_INSTRUCT_TEMPERATURE=0.3
# LLM_INSTRUCT_MAX_TOKENS=4096
