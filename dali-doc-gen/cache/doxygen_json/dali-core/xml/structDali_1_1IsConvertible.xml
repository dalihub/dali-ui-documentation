  <compounddef id="structDali_1_1IsConvertible" kind="struct" language="C++" prot="public">
    <compoundname>Dali::IsConvertible</compoundname>
    <basecompoundref refid="structDali_1_1Detail_1_1IsConvertibleImpl" prot="public" virt="non-virtual">Dali::Detail::IsConvertibleImpl&lt; From, To &gt;</basecompoundref>
    <includes refid="type-traits_8h" local="no">type-traits.h</includes>
    <templateparamlist>
      <param>
        <type>typename From</type>
      </param>
      <param>
        <type>typename To</type>
      </param>
    </templateparamlist>
    <briefdescription>
<para>Type trait to check if one type is implicitly convertible to another. </para>
    </briefdescription>
    <detaileddescription>
<para>Determines whether an imaginary rvalue of type From can be used to initialize an object or reference of type To.</para>
<para><parameterlist kind="templateparam"><parameteritem>
<parameternamelist>
<parametername>From</parametername>
</parameternamelist>
<parameterdescription>
<para>The source type to convert from </para>
</parameterdescription>
</parameteritem>
<parameteritem>
<parameternamelist>
<parametername>To</parametername>
</parameternamelist>
<parameterdescription>
<para>The target type to convert to</para>
</parameterdescription>
</parameteritem>
</parameterlist>
@SINCE_2_5.11</para>
<para>Example usage: <programlisting><codeline><highlight class="normal"><ref refid="structDali_1_1Detail_1_1IsConvertibleImpl_1a6e34ab5c9095c422b1bef050adea2cd4" kindref="member">IsConvertible&lt;int, float&gt;::value</ref>;<sp/><sp/><sp/><sp/><sp/><sp/><sp/><sp/></highlight><highlight class="comment">//<sp/>true<sp/>-<sp/>int<sp/>converts<sp/>to<sp/>float</highlight><highlight class="normal"></highlight></codeline>
<codeline><highlight class="normal"><ref refid="structDali_1_1Detail_1_1IsConvertibleImpl_1a6e34ab5c9095c422b1bef050adea2cd4" kindref="member">IsConvertible&lt;Base*, Derived*&gt;::value</ref>;<sp/><sp/><sp/></highlight><highlight class="comment">//<sp/>false<sp/>-<sp/>cannot<sp/>convert<sp/>derived<sp/>to<sp/>base<sp/>pointer</highlight><highlight class="normal"></highlight></codeline>
<codeline><highlight class="normal"><ref refid="structDali_1_1Detail_1_1IsConvertibleImpl_1a6e34ab5c9095c422b1bef050adea2cd4" kindref="member">IsConvertible&lt;Derived*, Base*&gt;::value</ref>;<sp/><sp/><sp/></highlight><highlight class="comment">//<sp/>true<sp/>-<sp/>derived<sp/>pointer<sp/>converts<sp/>to<sp/>base<sp/>pointer</highlight><highlight class="normal"></highlight></codeline>
<codeline><highlight class="normal"><ref refid="structDali_1_1Detail_1_1IsConvertibleImpl_1a6e34ab5c9095c422b1bef050adea2cd4" kindref="member">IsConvertible&lt;int*, float*&gt;::value</ref>;<sp/><sp/><sp/><sp/><sp/><sp/></highlight><highlight class="comment">//<sp/>false<sp/>-<sp/>pointer<sp/>types<sp/>are<sp/>unrelated</highlight></codeline>
</programlisting> </para>
