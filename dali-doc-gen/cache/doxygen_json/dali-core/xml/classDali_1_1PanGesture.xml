      <memberdef kind="function" id="classDali_1_1PanGesture_1aa4ba381ab1832fc0b0dfbb41ef5f863e" prot="public" static="no" const="yes" explicit="no" inline="no" virt="non-virtual">
        <type>float</type>
        <definition>float Dali::PanGesture::GetScreenDistance</definition>
        <argsstring>() const</argsstring>
        <name>GetScreenDistance</name>
        <qualifiedname>Dali::PanGesture::GetScreenDistance</qualifiedname>
        <briefdescription>
<para>This returns the distance the user has panned (dragged) since the last pan gesture in screen coordinates or, if the gesture has just started, then the distance in screen coordinates moved since the user touched the screen. </para>
        </briefdescription>
        <detaileddescription>
<para>This is always a positive value. @SINCE_1_9.28 <simplesect kind="return"><para>The distance, as a float, a user&apos;s finger has panned </para>
</simplesect>
</para>
        </detaileddescription>
