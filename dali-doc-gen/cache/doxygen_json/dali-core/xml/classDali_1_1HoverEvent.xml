      <memberdef kind="function" id="classDali_1_1HoverEvent_1a47b675a23ff38c7c12a9b51d9ed887f8" prot="public" static="no" const="yes" explicit="no" inline="no" virt="non-virtual">
        <type><ref refid="namespaceDali_1_1PointState_1a6a1bea9b393f61a1f5f54690c99918f7" kindref="member">PointState::Type</ref></type>
        <definition>PointState::Type Dali::HoverEvent::GetState</definition>
        <argsstring>(uint32_t point) const</argsstring>
        <name>GetState</name>
