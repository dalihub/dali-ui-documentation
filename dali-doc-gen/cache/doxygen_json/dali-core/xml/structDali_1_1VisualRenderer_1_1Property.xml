      <memberdef kind="enum" id="structDali_1_1VisualRenderer_1_1Property_1a7b07638761b2a9dedaab1f2fbf6e91f1" prot="public" static="no" strong="no">
        <type></type>
        <name></name>
        <qualifiedname>Dali::VisualRenderer::Property</qualifiedname>
        <enumvalue id="structDali_1_1VisualRenderer_1_1Property_1a7b07638761b2a9dedaab1f2fbf6e91f1a15acbceccc0d752519cfd49a251a5a63" prot="public">
          <name>TRANSFORM_OFFSET</name>
          <initializer>= DEFAULT_VISUAL_RENDERER_PROPERTY_START_INDEX</initializer>
          <briefdescription>
<para>Name &quot;transformOffset&quot;, type Property::Vector2, animatable. @SINCE_2_1.13. </para>
          </briefdescription>
          <detaileddescription>
<para><simplesect kind="note"><para>The default value is (0,0). </para>
</simplesect>
</para>
          </detaileddescription>
        </enumvalue>
        <enumvalue id="structDali_1_1VisualRenderer_1_1Property_1a7b07638761b2a9dedaab1f2fbf6e91f1a90dda035526684a060386d806d302453" prot="public">
          <name>TRANSFORM_SIZE</name>
          <briefdescription>
<para>Size of the visual, which can be either relative (percentage [0.0f to 1.0f] of the parent) or absolute (in world units). </para>
          </briefdescription>
          <detaileddescription>
<para>Name &quot;transformSize&quot;, type <ref refid="classDali_1_1Property_1ab466e94d7adc55576e8e86ee96db565daa5153e9670e8eeb32160ada6e41469a2" kindref="member">Property::VECTOR2</ref>, animatable. @SINCE_2_1.13 <simplesect kind="see"><para>TRANSFORM_SIZE_POLICY </para>
</simplesect>
</para>
          </detaileddescription>
        </enumvalue>
        <enumvalue id="structDali_1_1VisualRenderer_1_1Property_1a7b07638761b2a9dedaab1f2fbf6e91f1ac375d7866ff512d2ca4c91fa73ed8357" prot="public">
          <name>TRANSFORM_ORIGIN</name>
          <briefdescription>
<para>The origin of the visual renderer within its control area. </para>
          </briefdescription>
          <detaileddescription>
<para>Name &quot;transformOrigin&quot;, type <ref refid="classDali_1_1Property_1ab466e94d7adc55576e8e86ee96db565daa5153e9670e8eeb32160ada6e41469a2" kindref="member">Property::VECTOR2</ref> <simplesect kind="note"><para>This is relative to the size of the actor, where the origin is the center of the actor, and the range is -0.5 to +0.5 vertically and horizontally </para>
</simplesect>
<simplesect kind="note"><para>Toolkit may impose additional layout directions @SINCE_2_1.13 </para>
</simplesect>
<simplesect kind="note"><para>The default is top left </para>
</simplesect>
</para>
          </detaileddescription>
        </enumvalue>
        <enumvalue id="structDali_1_1VisualRenderer_1_1Property_1a7b07638761b2a9dedaab1f2fbf6e91f1a5765735475e6411faa698a921df85926" prot="public">
          <name>TRANSFORM_PIVOT</name>
          <briefdescription>
<para>The pivot of the visual renderer. </para>
          </briefdescription>
          <detaileddescription>
<para>Name &quot;transformPivot&quot;, type <ref refid="classDali_1_1Property_1ab466e94d7adc55576e8e86ee96db565daa5153e9670e8eeb32160ada6e41469a2" kindref="member">Property::VECTOR2</ref> <simplesect kind="note"><para>This is relative to the size of the actor; where the origin is the center of the actor, and the range is -0.5 to +0.5 vertically and horizontally </para>
</simplesect>
<simplesect kind="note"><para>Toolkit may impose additional layout directions @SINCE_2_1.13 </para>
</simplesect>
<simplesect kind="note"><para>The default is top left. </para>
</simplesect>
</para>
          </detaileddescription>
        </enumvalue>
        <enumvalue id="structDali_1_1VisualRenderer_1_1Property_1a7b07638761b2a9dedaab1f2fbf6e91f1a86c247468ee85351c8f92e21b5327fe3" prot="public">
          <name>TRANSFORM_OFFSET_SIZE_MODE</name>
          <briefdescription>
<para>Whether the x or y OFFSET/SIZE values are relative (percentage [0.0f to 1.0f] of the control) or absolute (in world units). </para>
          </briefdescription>
          <detaileddescription>
<para>Name &quot;transformOffsetSizeMode&quot;, type <ref refid="classDali_1_1Property_1ab466e94d7adc55576e8e86ee96db565da0229a22169799c1ebe54c9677c40ddaf" kindref="member">Property::VECTOR4</ref></para>
<para><programlisting><codeline><highlight class="normal">visualRenderer.SetProperty(<sp/><ref refid="structDali_1_1VisualRenderer_1_1Property_1a7b07638761b2a9dedaab1f2fbf6e91f1a86c247468ee85351c8f92e21b5327fe3" kindref="member">VisualRenderer::Property::TRANSFORM_OFFSET_SIZE_MODE</ref>,</highlight></codeline>
<codeline><highlight class="normal"><sp/><sp/><sp/><sp/><sp/><sp/><sp/><sp/><sp/><sp/><sp/><sp/><sp/><sp/><sp/><sp/><sp/><sp/><sp/><sp/><sp/><sp/><sp/><sp/><sp/><sp/><sp/><sp/>Vector4(<sp/>Policy::ABSOLUTE,<sp/>Policy::RELATIVE,<sp/>Policy::ABSOLUTE,<sp/>Policy::RELATIVE<sp/>));</highlight></codeline>
</programlisting> <simplesect kind="see"><para>Policy::Type @SINCE_2_1.13 </para>
</simplesect>
<simplesect kind="note"><para>By default, both the x and the y offset/size is RELATIVE. </para>
</simplesect>
</para>
          </detaileddescription>
        </enumvalue>
        <enumvalue id="structDali_1_1VisualRenderer_1_1Property_1a7b07638761b2a9dedaab1f2fbf6e91f1a8033687d7f4628ab09e5554be448d03a" prot="public">
          <name>EXTRA_SIZE</name>
          <briefdescription>
<para><ref refid="classDali_1_1Any" kindref="compound">Any</ref> extra size the shader needs for drawing into. </para>
          </briefdescription>
          <detaileddescription>
<para>Name &quot;extraSize&quot;, type <ref refid="classDali_1_1Property_1ab466e94d7adc55576e8e86ee96db565daa5153e9670e8eeb32160ada6e41469a2" kindref="member">Property::VECTOR2</ref>, animatable @SINCE_2_1.13 <simplesect kind="note"><para>the default is (0, 0) </para>
</simplesect>
</para>
          </detaileddescription>
        </enumvalue>
        <enumvalue id="structDali_1_1VisualRenderer_1_1Property_1a7b07638761b2a9dedaab1f2fbf6e91f1a2788e8957f6d848a1e90185379f16187" prot="public">
          <name>VISUAL_MIX_COLOR</name>
          <briefdescription>
<para>Mix color is a generic color for any visual. </para>
          </briefdescription>
          <detaileddescription>
<para>Name &quot;visualMixColor&quot;, type <ref refid="classDali_1_1Property_1ab466e94d7adc55576e8e86ee96db565da61265bdf25f65c089b1aed5f25d9b336" kindref="member">Property::VECTOR3</ref> @SINCE_2_1.13 @DEPRECATED_2_3.41 Use <ref refid="structDali_1_1Renderer_1_1Property_1a6cf60edf816f57e5d33c9badd2f027daa5c81688de02ef31e30788c21d53a6c64" kindref="member">Renderer::Property::MIX_COLOR</ref> instead. </para>
          </detaileddescription>
        </enumvalue>
        <enumvalue id="structDali_1_1VisualRenderer_1_1Property_1a7b07638761b2a9dedaab1f2fbf6e91f1a4d2dfd2554b2f9762b947ae0c9fb8d33" prot="public">
          <name>VISUAL_PRE_MULTIPLIED_ALPHA</name>
          <briefdescription>
<para>PremultipliedAlpha is a float representing a bool, and is either 0.0f, or 1.0f. </para>
          </briefdescription>
          <detaileddescription>
<para>Name &quot;visualPreMultipliedAlpha&quot;, type <ref refid="classDali_1_1Property_1ab466e94d7adc55576e8e86ee96db565daec08fcd8f68e1cfaa91a533f434d50d1" kindref="member">Property::FLOAT</ref> @SINCE_2_1.13 @DEPRECATED_2_3.41 Not be added as uniform anymore. Use <ref refid="structDali_1_1Renderer_1_1Property_1a6cf60edf816f57e5d33c9badd2f027daa6494cfbb2f5616ba90f0eb42764ea837" kindref="member">Renderer::Property::BLEND_PRE_MULTIPLIED_ALPHA</ref> instead. </para>
          </detaileddescription>
        </enumvalue>
