<parameternamelist>
<parametername direction="in">pixbuf</parametername>
</parameternamelist>
<parameterdescription>
<para>Pixel buffer to copy. </para>
</parameterdescription>
</parameteritem>
<parameteritem>
<parameternamelist>
<parametername direction="in">pixelFormat</parametername>
