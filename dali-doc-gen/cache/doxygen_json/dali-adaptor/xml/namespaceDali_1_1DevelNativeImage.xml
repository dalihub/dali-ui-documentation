      <memberdef kind="function" id="namespaceDali_1_1DevelNativeImage_1a348cd0b2daa6be43e2f20b5ee3527bd9" prot="public" static="no" const="no" explicit="no" inline="no" virt="non-virtual">
        <type>bool</type>
        <definition>DALI_ADAPTOR_API bool Dali::DevelNativeImage::ReleaseBuffer</definition>
        <argsstring>(NativeImage &amp;image, const Rect&lt; uint32_t &gt; &amp;updatedArea)</argsstring>
        <name>ReleaseBuffer</name>
        <qualifiedname>Dali::DevelNativeImage::ReleaseBuffer</qualifiedname>
        <param>
          <type><ref refid="classDali_1_1NativeImage" kindref="compound">NativeImage</ref> &amp;</type>
          <declname>image</declname>
        </param>
        <param>
          <type>const Rect&lt; uint32_t &gt; &amp;</type>
          <declname>updatedArea</declname>
        </param>
        <briefdescription>
<para>Release information of an internal native image. </para>
        </briefdescription>
        <detaileddescription>
<para><ref refid="namespaceDali_1_1DevelNativeImage_1aabcd46b9651b2f5d970060cf050990ef" kindref="member">AcquireBuffer()</ref> and <ref refid="namespaceDali_1_1DevelNativeImage_1a348cd0b2daa6be43e2f20b5ee3527bd9" kindref="member">ReleaseBuffer()</ref> are a pair. <ref refid="namespaceDali_1_1DevelNativeImage_1a348cd0b2daa6be43e2f20b5ee3527bd9" kindref="member">ReleaseBuffer()</ref> MUST be called after <ref refid="namespaceDali_1_1DevelNativeImage_1aabcd46b9651b2f5d970060cf050990ef" kindref="member">AcquireBuffer()</ref>. <parameterlist kind="param"><parameteritem>
<parameternamelist>
<parametername direction="in">image</parametername>
</parameternamelist>
<parameterdescription>
<para>The instance of <ref refid="classDali_1_1NativeImage" kindref="compound">NativeImage</ref>. </para>
</parameterdescription>
</parameteritem>
<parameteritem>
<parameternamelist>
<parametername direction="in">updatedArea</parametername>
</parameternamelist>
<parameterdescription>
<para>The updated area of the buffer. </para>
</parameterdescription>
</parameteritem>
</parameterlist>
<simplesect kind="return"><para><computeroutput>true</computeroutput> If the buffer is released successfully, and <computeroutput>false</computeroutput> otherwise </para>
</simplesect>
<simplesect kind="note"><para>The empty updatedArea means that the entire area has been changed. </para>
</simplesect>
<simplesect kind="note"><para>This unlocks the mutex locked by AcquireBuffer. </para>
</simplesect>
</para>
        </detaileddescription>
        <inbodydescription>
