    <detaileddescription>
<para><programlisting><codeline><highlight class="normal"><ref refid="classDali_1_1Ui_1_1BackgroundBlurEffect_1adececde29565f4545e1037fe17120f24" kindref="member">BackgroundBlurEffect</ref><sp/>effect<sp/>=<sp/><ref refid="classDali_1_1Ui_1_1BackgroundBlurEffect_1ab17aebf2077d82e0e554c036f7a74d20" kindref="member">BackgroundBlurEffect::New</ref>();</highlight></codeline>
<codeline><highlight class="normal">view.SetRenderEffect(effect);<sp/></highlight><highlight class="comment">//<sp/>Activate</highlight><highlight class="normal"></highlight></codeline>
