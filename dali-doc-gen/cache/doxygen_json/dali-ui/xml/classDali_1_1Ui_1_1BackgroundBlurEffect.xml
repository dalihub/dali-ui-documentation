        <briefdescription>
<para>Adds blur strength animation. Blurifies clear texture within given animation parameters. </para>
        </briefdescription>
        <detaileddescription>
<para><parameterlist kind="param"><parameteritem>
<parameternamelist>
<parametername direction="in">animation</parametername>
</parameternamelist>
<parameterdescription>
<para>Animation instance to which we add blur strength animation. </para>
</parameterdescription>
</parameteritem>
<parameteritem>
<parameternamelist>
<parametername direction="in">alphaFunction</parametername>
</parameternamelist>
<parameterdescription>
<para>AlphaFunction of blur strength animation. </para>
</parameterdescription>
</parameteritem>
<parameteritem>
<parameternamelist>
<parametername direction="in">timePeriod</parametername>
</parameternamelist>
<parameterdescription>
<para>TimePeriod of blur strength animation. Default value is animation&apos;s duration. </para>
</parameterdescription>
</parameteritem>
<parameteritem>
<parameternamelist>
<parametername direction="in">fromValue</parametername>
</parameternamelist>
<parameterdescription>
<para>Starting value of blur strength. Must be in range of [0.0f, 1.0f] </para>
</parameterdescription>
</parameteritem>
<parameteritem>
<parameternamelist>
<parametername direction="in">toValue</parametername>
</parameternamelist>
