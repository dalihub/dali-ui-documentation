    <sectiondef kind="enum">
      <memberdef kind="enum" id="namespaceDali_1_1Ui_1_1GradientVisual_1_1Property_1ab6ad2572c031c40291d66927c294b17e" prot="public" static="no" strong="no">
        <type></type>
        <name></name>
        <qualifiedname>Dali::Ui::GradientVisual::Property</qualifiedname>
        <enumvalue id="namespaceDali_1_1Ui_1_1GradientVisual_1_1Property_1ab6ad2572c031c40291d66927c294b17eab562fc97126d54a5394bdd61c732ef25" prot="public">
          <name>START_POSITION</name>
          <initializer>= VISUAL_PROPERTY_START_INDEX</initializer>
          <briefdescription>
<para>The start position of a linear gradient. </para>
          </briefdescription>
          <detaileddescription>
<para>Name &quot;startPosition&quot;, type Property::VECTOR2. Gradient is drawn in a rectangular area, TopLeft is (-0.5, -0.5) and BottomRight is (0.5, 0.5). The outside of the entered Start Position and End Position is extended to the value of the border. Even if the range between Start Position and End Position is greater than (-0.5, -0.5) to (0.5, 0.5), only the corresponding area is drawn. <simplesect kind="note"><para>Mandatory for Linear. </para>
</simplesect>
</para>
          </detaileddescription>
        </enumvalue>
        <enumvalue id="namespaceDali_1_1Ui_1_1GradientVisual_1_1Property_1ab6ad2572c031c40291d66927c294b17ea92905dfbff396acf1351f37db43d7aa5" prot="public">
          <name>END_POSITION</name>
          <briefdescription>
<para>The end position of a linear gradient. </para>
          </briefdescription>
          <detaileddescription>
<para>Name &quot;endPosition&quot;, type Property::VECTOR2. Gradient is drawn in a rectangular area, TopLeft is (-0.5, -0.5) and BottomRight is (0.5, 0.5). The outside of the entered Start Position and End Position is extended to the value of the border. Even if the range between Start Position and End Position is greater than (-0.5, -0.5) to (0.5, 0.5), only the corresponding area is drawn. <simplesect kind="note"><para>Mandatory for Linear. </para>
</simplesect>
</para>
          </detaileddescription>
        </enumvalue>
        <enumvalue id="namespaceDali_1_1Ui_1_1GradientVisual_1_1Property_1ab6ad2572c031c40291d66927c294b17ea4a4abe1478a770bf001b521b3311578a" prot="public">
          <name>CENTER</name>
          <briefdescription>
<para>The center point of a radial gradient. </para>
          </briefdescription>
          <detaileddescription>
<para>Name &quot;center&quot;, type Property::VECTOR2. <simplesect kind="note"><para>Mandatory for Radial and Conic. </para>
</simplesect>
</para>
          </detaileddescription>
        </enumvalue>
        <enumvalue id="namespaceDali_1_1Ui_1_1GradientVisual_1_1Property_1ab6ad2572c031c40291d66927c294b17ea89d1a36f2e1600fb26ec99f86bc9e37a" prot="public">
          <name>RADIUS</name>
          <briefdescription>
<para>The size of the radius of a radial gradient. </para>
          </briefdescription>
          <detaileddescription>
<para>Name &quot;radius&quot;, type Property::FLOAT. <simplesect kind="note"><para>Mandatory for Radial. </para>
</simplesect>
</para>
          </detaileddescription>
        </enumvalue>
        <enumvalue id="namespaceDali_1_1Ui_1_1GradientVisual_1_1Property_1ab6ad2572c031c40291d66927c294b17ea629d0d55cda08f91c08dd469adc8c971" prot="public">
          <name>STOP_OFFSET</name>
          <briefdescription>
<para>All the stop offsets. </para>
          </briefdescription>
          <detaileddescription>
<para>Name &quot;stopOffset&quot;, type Property::ARRAY of Property::FLOAT. <simplesect kind="note"><para>Optional. If not supplied, default is 0.0 and 1.0. </para>
</simplesect>
</para>
          </detaileddescription>
        </enumvalue>
        <enumvalue id="namespaceDali_1_1Ui_1_1GradientVisual_1_1Property_1ab6ad2572c031c40291d66927c294b17ea52effa140a62bc33614ae7c4d7e17c71" prot="public">
          <name>STOP_COLOR</name>
          <briefdescription>
<para>The color at the stop offsets. </para>
          </briefdescription>
          <detaileddescription>
<para>Name &quot;stopColor&quot;, type Property::ARRAY of Property::VECTOR4. <simplesect kind="note"><para>Mandatory. At least 2 values required to show a gradient. </para>
</simplesect>
</para>
          </detaileddescription>
        </enumvalue>
        <enumvalue id="namespaceDali_1_1Ui_1_1GradientVisual_1_1Property_1ab6ad2572c031c40291d66927c294b17ea680a9ebd79b64bc54750e6ff72f2cbde" prot="public">
          <name>UNITS</name>
          <briefdescription>
<para>Defines the coordinate system for certain attributes of the points in a gradient. </para>
          </briefdescription>
          <detaileddescription>
<para>Name &quot;units&quot;, type <ref refid="namespaceDali_1_1Ui_1_1GradientVisual_1_1Units_1a49cf9c816d9cf5d26f20ce1c79ca8816" kindref="member">Units::Type</ref> (Property::INTEGER) or Property::STRING. <simplesect kind="note"><para>Optional. If not supplied, default is <ref refid="namespaceDali_1_1Ui_1_1GradientVisual_1_1Units_1a49cf9c816d9cf5d26f20ce1c79ca8816a24a0099b6435b87f997c71e8877b2c5b" kindref="member">Units::OBJECT_BOUNDING_BOX</ref>. </para>
</simplesect>
<simplesect kind="see"><para><ref refid="namespaceDali_1_1Ui_1_1GradientVisual_1_1Units_1a49cf9c816d9cf5d26f20ce1c79ca8816" kindref="member">Units::Type</ref> </para>
</simplesect>
</para>
          </detaileddescription>
        </enumvalue>
        <enumvalue id="namespaceDali_1_1Ui_1_1GradientVisual_1_1Property_1ab6ad2572c031c40291d66927c294b17ea66385a87b628bd1b3133f2012a41d193" prot="public">
          <name>SPREAD_METHOD</name>
          <briefdescription>
<para>Indicates what happens if the gradient starts or ends inside the bounds of the target rectangle. </para>
          </briefdescription>
          <detaileddescription>
<para>Name &quot;spreadMethod&quot;, type <ref refid="namespaceDali_1_1Ui_1_1GradientVisual_1_1SpreadMethod_1a900e78c5ac8c2ecbb0657b13ff9af943" kindref="member">SpreadMethod::Type</ref> (Property::INTEGER) or Property::STRING. <simplesect kind="note"><para>Optional. If not supplied, default is <ref refid="namespaceDali_1_1Ui_1_1GradientVisual_1_1SpreadMethod_1a900e78c5ac8c2ecbb0657b13ff9af943a181b3cff5f2c496e9461bddf5f402406" kindref="member">SpreadMethod::PAD</ref>. </para>
</simplesect>
<simplesect kind="see"><para><ref refid="namespaceDali_1_1Ui_1_1GradientVisual_1_1SpreadMethod_1a900e78c5ac8c2ecbb0657b13ff9af943" kindref="member">SpreadMethod::Type</ref> </para>
</simplesect>
</para>
          </detaileddescription>
        </enumvalue>
        <enumvalue id="namespaceDali_1_1Ui_1_1GradientVisual_1_1Property_1ab6ad2572c031c40291d66927c294b17ea3ac1eeda2296e2577acccf56f0e59afd" prot="public">
          <name>START_OFFSET</name>
          <briefdescription>
<para>The offset value that shifts the starting position of the gradient. </para>
          </briefdescription>
          <detaileddescription>
<para>Name &quot;startOffset&quot;, type Property::FLOAT. <simplesect kind="note"><para>Optional. If not supplied, default is 0. </para>
</simplesect>
</para>
          </detaileddescription>
        </enumvalue>
        <enumvalue id="namespaceDali_1_1Ui_1_1GradientVisual_1_1Property_1ab6ad2572c031c40291d66927c294b17ea32c1cc958e7246cc4d83c4e83544966c" prot="public">
          <name>START_ANGLE</name>
          <briefdescription>
<para>The initial angle from which the conic gradient begins. </para>
          </briefdescription>
          <detaileddescription>
<para>Name &quot;startAngle&quot;, type Property::FLOAT. <simplesect kind="note"><para>Mandatory for Conic. </para>
</simplesect>
</para>
          </detaileddescription>
        </enumvalue>
        <briefdescription>
<para>Enumeration for the instance of properties belonging to the <ref refid="namespaceDali_1_1Ui_1_1GradientVisual" kindref="compound">GradientVisual</ref>. </para>
