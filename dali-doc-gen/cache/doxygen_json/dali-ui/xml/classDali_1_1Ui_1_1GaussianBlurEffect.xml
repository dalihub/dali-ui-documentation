        <argsstring>(Animation &amp;animation, AlphaFunction alphaFunction, TimePeriod timePeriod, float fromValue, float toValue)</argsstring>
        <name>AddBlurStrengthAnimation</name>
        <qualifiedname>Dali::Ui::GaussianBlurEffect::AddBlurStrengthAnimation</qualifiedname>
        <param>
          <type>Animation &amp;</type>
          <declname>animation</declname>
        </param>
        <param>
          <type>AlphaFunction</type>
          <declname>alphaFunction</declname>
        </param>
        <param>
          <type>TimePeriod</type>
          <declname>timePeriod</declname>
        </param>
        <param>
          <type>float</type>
          <declname>fromValue</declname>
        </param>
        <param>
          <type>float</type>
          <declname>toValue</declname>
        </param>
        <briefdescription>
<para>Adds blur strength animation. Blurifies clear texture within given animation parameters. </para>
        </briefdescription>
        <detaileddescription>
<para><parameterlist kind="param"><parameteritem>
<parameternamelist>
<parametername direction="in">animation</parametername>
</parameternamelist>
<parameterdescription>
<para>Animation instance to which we add blur strength animation. </para>
</parameterdescription>
</parameteritem>
<parameteritem>
<parameternamelist>
<parametername direction="in">alphaFunction</parametername>
</parameternamelist>
<parameterdescription>
<para>AlphaFunction of blur strength animation. </para>
</parameterdescription>
</parameteritem>
<parameteritem>
<parameternamelist>
<parametername direction="in">timePeriod</parametername>
</parameternamelist>
<parameterdescription>
<para>TimePeriod of blur strength animation. Default value is animation&apos;s duration. </para>
</parameterdescription>
</parameteritem>
<parameteritem>
<parameternamelist>
<parametername direction="in">fromValue</parametername>
</parameternamelist>
<parameterdescription>
<para>Starting value of blur strength. Must be in range of [0.0f, 1.0f] </para>
</parameterdescription>
</parameteritem>
<parameteritem>
<parameternamelist>
<parametername direction="in">toValue</parametername>
</parameternamelist>
<parameterdescription>
<para>End value of blur strength. Must be in range of [0.0f, 1.0f] </para>
</parameterdescription>
</parameteritem>
</parameterlist>
<simplesect kind="note"><para>If toValue is smaller than fromValue, animation would show reversed(blurred-&gt;clarified) animation. </para>
</simplesect>
<simplesect kind="note"><para>When choosing alpha function, note that gaussian curve itself is innately non-linear. </para>
</simplesect>
</para>
        </detaileddescription>
