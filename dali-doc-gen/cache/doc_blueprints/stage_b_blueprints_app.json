      {
        "section_title": "Overview",
        "description": "AnimatedImageView is a specialized UI component designed for rendering and controlling animated GIF and WEBP media files within your application layout."
      },
      {
        "section_title": "Getting Started",
        "description": "Learn how to instantiate an AnimatedImageView using the Factory pattern and integrate it into your Dali UI View hierarchy."
      },
      {
        "section_title": "Loading and Resource Management",
        "description": "Configure image source URLs, manage load/release policies, and define placeholder assets to ensure smooth UI transitions."
      },
      {
        "section_title": "Playback Control and State",
        "description": "Manage animation flow with commands like Play, Pause, and Stop, and track playback progress using frame indices and speed factors."
      },
      {
        "section_title": "Visual Configuration and Styling",
        "description": "Adjust image appearance through color modulation, alpha masking, pixel area cropping, and scaling modes to match your design requirements."
      },
      {
        "section_title": "Memory and Performance Optimization",
        "description": "Optimize resource usage by tuning batch sizes, cache limits, and synchronous loading flags to maintain a high frame rate."
      },
      {
        "section_title": "Event Handling",
        "description": "Respond to lifecycle events and animation milestones using signal handlers to synchronize your app logic with image playback states."
      },
      {
