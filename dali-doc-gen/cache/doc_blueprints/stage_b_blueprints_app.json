      {
        "section_title": "Overview",
        "description": "The DALi layout system provides a declarative mechanism to automate UI component positioning and sizing within Dali::Ui::View hierarchies, ensuring responsive interfaces across varying screen dimensions."
      },
      {
        "section_title": "Getting Started with View Layouts",
        "description": "Learn the fundamental pattern of assigning layout engines to views using SetLayoutParams to establish parent-child positioning rules."
      },
      {
        "section_title": "Flexbox-based Positioning",
        "description": "Utilize FlexLayout and FlexLayoutParams to create flexible, responsive UI designs that automatically adjust to screen space and content flow."
      },
      {
        "section_title": "Grid-based Arrangements",
        "description": "Organize UI elements into structured rows and columns using GridLayout and GridLayoutParams for precise, tabular component placement."
      },
      {
        "section_title": "Stack and Absolute Positioning",
        "description": "Implement simple sequential stacking or coordinate-based absolute positioning using StackLayout and AbsoluteLayout for specialized view arrangements."
      },
      {
        "section_title": "Configuring Layout Geometry",
        "description": "Manage dimensions and coordinate alignment by interacting with LayoutRect and MeasuredSize to influence how views occupy their allocated space."
      },
      {
        "section_title": "Managing Layout Lifecycle",
        "description": "Understand how the LayoutController tracks registered views and manages the lifecycle of layout updates to maintain UI synchronization."
      }
    ]
